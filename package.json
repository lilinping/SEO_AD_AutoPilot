{
  "name": "seo-ad-autopilot",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.1",
  "workspaces": [
    "apps/web",
    "packages/contracts"
  ],
  "scripts": {
    "api:dev": "./.venv/bin/uvicorn apps.api.seo_ad_autopilot.app:create_app --factory --reload --host 127.0.0.1 --port 8000",
    "api:test": "./.venv/bin/python -m unittest apps.api.tests.test_smoke_unittest -v",
    "web:dev": "pnpm --dir apps/web dev",
    "web:build": "pnpm --dir apps/web build",
    "web:typecheck": "pnpm --dir apps/web typecheck",
    "test": "./.venv/bin/python -m unittest apps.api.tests.test_smoke_unittest -v"
  }
}
