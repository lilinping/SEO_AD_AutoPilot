FROM node:18-alpine

WORKDIR /app

# Copy package files
COPY apps/web/package.json apps/web/pnpm-lock.yaml ./

# Install pnpm
RUN npm install -g pnpm

# Install dependencies
RUN pnpm install --frozen-lockfile

# Copy application code
COPY apps/web/ ./

# Build the application
RUN pnpm build

# Expose port
EXPOSE 3000

# Run the application
CMD ["pnpm", "start"]
