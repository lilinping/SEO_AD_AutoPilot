ENABLE_PDF_EXPORT=false
SEO_AD_BOT_ENABLE_BETTAFISH_RENDERERS=false
OUTPUT_DIR=final_reports
CHAPTER_OUTPUT_DIR=final_reports/chapters
DOCUMENT_IR_OUTPUT_DIR=final_reports/ir
LOG_FILE=logs/report.log

