DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/seo_ad_bot
SEO_AD_BOT_API_KEY=dev-key
SEO_AD_BOT_DEFAULT_WORKSPACE=demo-pack
SEO_AD_BOT_PREFER_NEXT_APP=true
SEO_AD_BOT_NEXT_APP_URL=http://127.0.0.1:3000/app
SEO_AD_BOT_WEB_ORIGIN=http://127.0.0.1:3000
SEO_AD_BOT_STATE_DIR=var
SEO_AD_BOT_SKILL_REGISTRY_PATH=packages/skill-registry/registry.json
NEXT_PUBLIC_AUTOPILOT_API_URL=http://127.0.0.1:8000/api
SEO_AD_BOT_AUTO_DEPLOY_ENABLED=true
SEO_AD_BOT_APPROVAL_REQUIRED_THRESHOLD=60
SEO_AD_BOT_BLOCK_AUTO_DEPLOY_THRESHOLD=80
SEO_AD_BOT_MONITOR_WINDOW_MINUTES=90
SEO_AD_BOT_ROLLBACK_WINDOW_MINUTES=5
SEO_AD_BOT_ENABLE_BROWSER_CRAWL=false

